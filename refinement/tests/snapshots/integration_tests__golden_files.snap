---
source: refinement/tests/integration_tests.rs
expression: output
input_file: refinement/tests/test_lines.txt
---
# Base literals
5 : { v : Int | v = 5 }
true : { v : Bool | v = true }
1 + 2 : { v : Int | v = 1 + 2 }

# Variables and let
let x = 5 in x + 1 : { v : Int | v = x + 1 }
let x = 10 in x * x : { v : Int | v = x * x }

# Lambdas with refined argument types
\x : { n : Int | n > 0 } -> x : (x : { n : Int | n > 0 }) -> { v : Int | v > 0 && v = x }
\x : Int -> x + 1 : (x : Int) -> { v : Int | v = x + 1 }

# Dependent application with positive argument
(\x : { n : Int | n > 0 } -> x) 3 : { v : Int | v > 0 && v = 3 }

# Built-in division by non-zero literal
(\x : { n : Int | n != 0 } -> div 10 x) 2 : Int

# Path conditions from if
\x : Int -> if x > 0 then x else 0 - x : Int -> Int

# Negative: divide by zero
div 10 0 : ERROR: Refinement obligation failed: v_1 = 0 => v_1 != 0 (counterexample: v_1 = 0)

# Negative: pass possibly-zero where non-zero required
\x : Int -> div 10 x : ERROR: Refinement obligation failed: v_1 = x => v_1 != 0 (counterexample: v_1 = 0, x = 0)

# Negative: subtype mismatch on argument
let y = 0 in (\x : { n : Int | n > 0 } -> x) y : ERROR: Refinement obligation failed: v_0 = 0 && v_0 = y => v_0 > 0 (counterexample: v_0 = 0, y = 0)

# Negative: pass negative where positive required
(\x : { n : Int | n > 0 } -> x) (0 - 5) : ERROR: Refinement obligation failed: v_2 = 0 - 5 => v_2 > 0 (counterexample: v_2 = -5)
