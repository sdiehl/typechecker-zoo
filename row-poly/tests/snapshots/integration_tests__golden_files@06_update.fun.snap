source: row-poly/tests/integration_tests.rs
expression: output
input_file: row-poly/tests/06_update.fun
---
# Update: {l := e | r} desugars to {l = e | {r - l}}.
# Because of that desugaring, update can change a field's type.

# Update preserving the type.
let p = {x = 1, y = 2} in {x := 99 | p} : {x : Int, y : Int}

# Update changing the type (heterogeneous update).
let p = {x = 1, y = 2} in {x := true | p} : {x : Bool, y : Int}

# Update on a polymorphic record.
\r -> {x := 0 | r} : {x : a | r} -> {x : Int | r}
\r -> {x := true | r} : {x : a | r} -> {x : Bool | r}

# Update twice on the same label.
let p = {x = 1} in {x := false | {x := true | p}} : {x : Bool}

# Update preserves the rest of the row.
let p = {x = 1, y = 2, z = 3} in ({x := true | p}).y : Int
let p = {x = 1, y = 2, z = 3} in ({x := true | p}).z : Int

# Update on a duplicate field hits the leftmost (the duplicate stays).
let p = {x = 1, x = true} in {x := false | p} : {x : Bool, x : Bool}
let p = {x = 1, x = true} in ({x := false | p}).x : Bool

# Updating creates a record whose row is open if the source is open.
\r -> ({x := 1 | r}).x : {x : a | r} -> Int

# Building an updater function.
let setx = \v -> \r -> {x := v | r} in setx 42 {x = 1, y = 2} : {x : Int, y : Int}
let setx = \v -> \r -> {x := v | r} in setx true {x = 1} : {x : Bool}
