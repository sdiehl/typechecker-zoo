expression: output
input_file: row-poly/tests/03_selection.fun
---
# Selection in all its forms. Selection's principal type is
#   (.l) : forall r a. {l : a | r} -> a

# Direct selection from a literal.
{x = 42}.x : Int

# Selection through let.
let p = {x = 1, y = 2} in p.x : Int
let p = {x = 1, y = 2} in {a = p.x, b = p.y} : {a : Int, b : Int}

# Selection inside a lambda forces a row-polymorphic type.
\r -> r.x : {x : a | r} -> a
\r -> r.foo : {foo : a | r} -> a

# Two selections from the same row reuse the row variable.
\r -> \s -> r.x : {x : b | r} -> a -> b

# Two selections from different records are independent.
\r -> \s -> r.x : {x : b | r} -> a -> b

# Polymorphic selector functions.
let getx = \r -> r.x in getx {x = 1} : Int
let getx = \r -> r.x in getx {x = true} : Bool
let getx = \r -> r.x in {a = getx {x = 1, y = 2}, b = getx {x = false, z = 3}} : {a : Int, b : Bool}

# Selection on extension.
({x = 1 | {y = 2}}).x : Int
({x = 1 | {y = 2}}).y : Int

# Function returning a selector.
\l -> l.field : {field : a | r} -> a

# Higher-order: pass selector as argument.
\f -> \r -> f r : (a -> b) -> a -> b

# Compose selectors via let.
let getx = \r -> r.x in let gety = \r -> r.y in \r -> getx r : {x : a | r} -> a
